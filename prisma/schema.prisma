generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FoodType {
  upf
  fresh
}

model Food {
  id          String   @id @default(uuid())
  name        String
  ingredients String
  description String
  type        FoodType
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}